{
  "functions": {
    "server.js": {
      "includeFiles": [
        "index.html",
        "client.js",
        "data.js",
        "services.js",
        "styles.css",
        "vendor/**",
        "assets/**"
      ]
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/server.js"
    }
  ]
}
